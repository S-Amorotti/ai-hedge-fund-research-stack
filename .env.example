# ──────────────────────────────────────────────────────────────────────────────
# Database (required)
# ──────────────────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string used by the app.
# Must point to the same DB that docker-compose spins up.
DATABASE_URL=postgresql://postgres:changeme@localhost:5433/ai_hedge_fund

# ──────────────────────────────────────────────────────────────────────────────
# Docker Compose (infra/docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────────────

# Password for the Postgres container — must match DATABASE_URL above.
POSTGRES_PASSWORD=changeme

# Optional overrides (defaults shown):
# POSTGRES_USER=postgres
# POSTGRES_DB=ai_hedge_fund
# POSTGRES_HOST_PORT=5433

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────

# Path for the append-only JSONL decision log.
# LOG_PATH=app/monitoring/decisions.log

# Rotate the log when it exceeds this size in bytes (default: 10 MB).
# MAX_LOG_BYTES=10485760

# Number of rotated backup files to keep (default: 5).
# LOG_BACKUP_COUNT=5

# ──────────────────────────────────────────────────────────────────────────────
# Orchestration
# ──────────────────────────────────────────────────────────────────────────────

# Maximum number of executor retries after a critic veto (default: 2).
# MAX_RETRIES=2

# Minimum Prediction Consistency score to pass the critic gate (default: 0.7).
# PC_THRESHOLD=0.7

# ──────────────────────────────────────────────────────────────────────────────
# Kill switch / human approval flag files
# ──────────────────────────────────────────────────────────────────────────────

# Path to the pause flag file. Creating this file halts execution at the next node.
# PAUSE_FLAG=app/monitoring/pause.flag

# Path to the approval flag file. Written by the dashboard approve/reject buttons.
# APPROVAL_FLAG=app/monitoring/approval.flag

# ──────────────────────────────────────────────────────────────────────────────
# Prefect (optional — only needed for prefect_flow.py)
# ──────────────────────────────────────────────────────────────────────────────

# Default research hypothesis for the Prefect-orchestrated flow.
# HYPOTHESIS=Hypothesis: earnings sentiment predicts short-term drift
